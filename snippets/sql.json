	},
	"Postgres: Sample Temp Function": {
		"prefix": [
			"function",
			"temp",
			"delete_all_function"
		],
		"body": [
			"DO $$ ",
			"DECLARE",
			"    r RECORD;",
			"BEGIN",
			"    -- Loop through all user-defined functions in the 'public' schema (change schema if needed)",
			"    FOR r IN ",
			"        SELECT n.nspname AS schema_name, ",
			"               p.proname AS function_name, ",
			"               pg_catalog.pg_get_function_identity_arguments(p.oid) AS args",
			"        FROM pg_proc p",
			"        JOIN pg_namespace n ON p.pronamespace = n.oid",
			"        WHERE n.nspname = 'public'  -- Specify your schema here, 'public' by default",
			"        AND n.nspname NOT IN ('pg_catalog', 'information_schema')  -- Exclude system schemas",
			"    LOOP",
			"        -- Execute drop statement for each function",
			"        EXECUTE 'DROP FUNCTION IF EXISTS ' || r.schema_name || '.' || r.function_name || '(' || r.args || ') CASCADE';",
			"    END LOOP;",
			"END $$;"
		],
		"description": "Postgres: Sample Temp Function"
	},
	"Postgres: Sample Table with Function": {
		"prefix": "sample_tbl",
		"body": [
			"CREATE TABLE TSample (",
			"    SampleId INT PRIMARY KEY GENERATED ALWAYS AS IDENTITY,",
			"    Title VARCHAR,",
			"    Description VARCHAR,",
			"    Price DECIMAL(10,6),",
			"    Quantity INT,",
			"    CreatedBy VARCHAR,",
			"    CreatedAt TIMESTAMP",
			");",
			"",
			"-- Stored Procedure: Select All Record",
			"CREATE OR REPLACE FUNCTION NSP_TSample_SelectAll(",
			"    p_SampleId INT DEFAULT -1",
			")",
			"RETURNS TABLE (",
			"    t_SampleId INT,",
			"    t_Title VARCHAR,",
			"    t_Description VARCHAR,",
			"    t_Price DECIMAL(10,6),",
			"    t_Quantity INT,",
			"    t_CreatedBy VARCHAR,",
			"    t_CreatedAt TIMESTAMP",
			") ",
			"AS \\$func$",
			"BEGIN",
			"    RETURN QUERY",
			"    SELECT * ",
			"    FROM TSample ",
			"    WHERE 1=1",
			"    AND CASE WHEN p_SampleId = -1 THEN p_SampleId ELSE SampleId END = p_SampleId ",
			"    ORDER BY SampleId;",
			"    -- SELECT * FROM NSP_TSample_SelectAll();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
			"",
			"-- Stored Procedure: Select By Primary Key",
			"CREATE OR REPLACE FUNCTION NSP_TSample_SelectByPk(",
			"    p_SampleId INT DEFAULT -1",
			")",
			"RETURNS TABLE (",
			"    t_SampleId INT,",
			"    t_Title VARCHAR,",
			"    t_Description VARCHAR,",
			"    t_Price DECIMAL(10,6),",
			"    t_Quantity INT,",
			"    t_CreatedBy VARCHAR,",
			"    t_CreatedAt TIMESTAMP",
			") ",
			"AS \\$func$",
			"BEGIN",
			"    RETURN QUERY",
			"    SELECT * ",
			"    FROM TSample ",
			"    WHERE SampleId = p_SampleId;",
			"    -- SELECT * FROM NSP_TSample_SelectByPk();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
			"",
			"-- Stored Procedure: Select For DropDown",
			"CREATE OR REPLACE FUNCTION NSP_TSample_SelectDropDown(",
			"    p_SampleId INT,",
			"    p_SelectedAll INT DEFAULT 0",
			")",
			"RETURNS TABLE (",
			"    t_ValueField INT,",
			"    t_TextField VARCHAR",
			")",
			"AS \\$func$",
			"BEGIN",
			"    CREATE TEMP TABLE NewList (",
			"        ValueField INT,",
			"        TextField VARCHAR",
			"    ) ON COMMIT DROP;",
			"",
			"    IF p_SelectedAll = -1 THEN",
			"        INSERT INTO NewList(ValueField, TextField)",
			"        VALUES (-1, 'Selected All');",
			"    END IF;",
			"",
			"    INSERT INTO NewList",
			"    SELECT SampleId, Title",
			"    FROM TSample",
			"    WHERE 1=1",
			"    AND CASE WHEN p_SampleId = -1 THEN p_SampleId ELSE SampleId END = p_SampleId ",
			"    ORDER BY Title;",
			"",
			"    RETURN QUERY",
			"    SELECT * ",
			"    FROM NewList",
			"    WHERE 1=1;",
			"    -- SELECT * FROM NSP_TSample_SelectDropDown();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
			"",
			"-- Stored Procedure: Insert New Record",
			"CREATE OR REPLACE FUNCTION NSP_TSample_Insert(",
			"    p_Title VARCHAR,",
			"    p_Description VARCHAR,",
			"    p_Price DECIMAL(10,6),",
			"    p_Quantity INT,",
			"    p_CreatedBy VARCHAR,",
			"    p_CreatedAt TIMESTAMP",
			")",
			"RETURNS VOID",
			"AS \\$func$",
			"BEGIN",
			"    INSERT INTO TSample (",
			"        Title,",
			"        Description,",
			"        Price,",
			"        Quantity,",
			"        CreatedBy,",
			"        CreatedAt",
			"    )",
			"    VALUES (",
			"        p_Title,",
			"        p_Description,",
			"        p_Price,",
			"        p_Quantity,",
			"        p_CreatedBy,",
			"        p_CreatedAt",
			"    );",
			"    -- SELECT NSP_TSample_Insert();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
			"",
			"-- Stored Procedure: Update Existing Record",
			"CREATE OR REPLACE FUNCTION NSP_TSample_Update(",
			"    p_SampleId INT,",
			"    p_Title VARCHAR,",
			"    p_Description VARCHAR,",
			"    p_Price DECIMAL(10,6),",
			"    p_Quantity INT,",
			"    p_CreatedBy VARCHAR,",
			"    p_CreatedAt TIMESTAMP",
			")",
			"RETURNS VOID",
			"AS \\$func$",
			"BEGIN",
			"    UPDATE TSample",
			"    SET ",
			"        Title = p_Title,",
			"        Description = p_Description,",
			"        Price = p_Price,",
			"        Quantity = p_Quantity,",
			"        CreatedBy = p_CreatedBy,",
			"        CreatedAt = p_CreatedAt",
			"    WHERE 1=1",
			"    AND SampleId = p_SampleId;",
			"    -- SELECT NSP_TSample_Update();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
			"",
			"-- Stored Procedure: Delete Existing Record",
			"CREATE OR REPLACE FUNCTION NSP_TSample_Delete(",
			"    p_SampleId INT",
			")",
			"RETURNS VOID",
			"AS \\$func$",
			"BEGIN",
			"    DELETE FROM TSample",
			"    WHERE 1=1",
			"    AND SampleId = p_SampleId;",
			"    -- SELECT NSP_TSample_Delete();",
			"END;",
			"\\$func$ LANGUAGE plpgsql;",
