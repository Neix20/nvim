        ],
        "path": "./javascript.json"
      },
      {
        "language": [
          "nginx"
        ],
        "path": "./nginx.json"
      },
      {
        "language": [
          "python"
        ],
        "path": "./python.json"
      },
      {
        "language": [
          "terraform"
        ],
        "path": "./terraform.json"
