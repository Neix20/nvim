			"",
			"    try {",
			"        // Write Business Logic",
			"        ${2:funcBody}",
			"    } catch (err) {",
			"        const obj = genErrObj(funcName, err);",
			"        clsLogger.error(obj);",
			"        return next(new AppError(obj.message, obj.statusCode, obj.error));",
			"    }",
			"",
			"    const respMsg = \"Success!\";",
			"    clsLogger.info(genRespObj(STATUS_CODES.OK, respMsg, resData));",
