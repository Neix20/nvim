{
	"CMakeLists": {
		"prefix": "cmake",
		"body": [
			"cmake_minimum_required(VERSION 3.10)",
			"",
			"# set the project name",
			"project($proj_name)",
			"",
			"# add the executable",
			"add_executable(",
			"    $proj_name main.cpp",
			")"
		],
		"description": "Generate Boilerplate for CMake Lists"
	}
}
